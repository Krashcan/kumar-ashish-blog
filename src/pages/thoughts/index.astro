---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Main from "@/layouts/Main.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LinkButton from "@/components/LinkButton.astro";
import getSortedThoughts from "@/utils/getSortedThoughts";
import { getThoughtSlug } from "@/utils/getThoughtSlug";
import { SITE } from "@/config";

const thoughts = await getCollection("thoughts");
const sortedThoughts = getSortedThoughts(thoughts);

// Group by folder-derived slug
const slugGroups = new Map<string, number>();
for (const thought of sortedThoughts) {
  const slug = getThoughtSlug(thought.id);
  const count = slugGroups.get(slug) ?? 0;
  slugGroups.set(slug, count + 1);
}
---

<Layout title={`Thoughts | ${SITE.title}`}>
  <Header />
  <Main pageTitle="Thoughts" pageDesc="Short notes, observations, and random musings.">
    <ul class="flex flex-col gap-4">
      {
        Array.from(slugGroups.entries()).map(([slug, count]) => (
          <li>
            <LinkButton href={`/thoughts/${slug}`} class="text-lg">
              {slug}
              <span class="ml-2 text-sm opacity-70">({count})</span>
            </LinkButton>
          </li>
        ))
      }
    </ul>
  </Main>
  <Footer />
</Layout>
