---
import { getCollection } from "astro:content";
import type { GetStaticPathsOptions } from "astro";
import Main from "@/layouts/Main.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import ThoughtCard from "@/components/ThoughtCard.astro";
import Pagination from "@/components/Pagination.astro";
import getUniqueTags from "@/utils/getUniqueTags";
import getPostsByTag, { getThoughtsByTag } from "@/utils/getPostsByTag";
import { SITE } from "@/config";

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const posts = await getCollection("blog");
  const thoughts = await getCollection("thoughts");
  const tags = getUniqueTags(posts, thoughts);

  return tags.flatMap(({ tag, tagName }) => {
    const tagPosts = getPostsByTag(posts, tag);
    const tagThoughts = getThoughtsByTag(thoughts, tag);

    // Create a unified list sorted by date
    type FeedItem =
      | { type: "post"; item: (typeof tagPosts)[number] }
      | { type: "thought"; item: (typeof tagThoughts)[number] };

    const feed: FeedItem[] = [
      ...tagPosts.map(item => ({ type: "post" as const, item })),
      ...tagThoughts.map(item => ({ type: "thought" as const, item })),
    ].sort((a, b) => {
      const dateA = new Date(
        a.item.data.modDatetime ?? a.item.data.pubDatetime
      ).getTime();
      const dateB = new Date(
        b.item.data.modDatetime ?? b.item.data.pubDatetime
      ).getTime();
      return dateB - dateA;
    });

    return paginate(feed, {
      params: { tag },
      props: { tagName },
      pageSize: SITE.postPerPage,
    });
  });
}

const params = Astro.params;
const { tag } = params;
const { page, tagName } = Astro.props;
---

<Layout title={`Tag: ${tagName} | ${SITE.title}`}>
  <Header />
  <Main
    pageTitle={[`Tag:`, `${tagName}`]}
    titleTransition={tag}
    pageDesc={`All the articles with the tag "${tagName}".`}
  >
    <h1 slot="title" transition:name={tag}>{`Tag:${tag}`}</h1>
    <ul>
      {
        page.data.map(({ type, item }: any) =>
          type === "post" ? (
            <Card {...item} />
          ) : (
            <ThoughtCard {...item} />
          )
        )
      }
    </ul>
  </Main>

  <Pagination {page} />

  <Footer noMarginTop={page.lastPage > 1} />
</Layout>
