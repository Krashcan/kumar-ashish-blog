---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import ThoughtCard from "@/components/ThoughtCard.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import getSortedThoughts from "@/utils/getSortedThoughts";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";

const posts = await getCollection("blog");
const thoughts = await getCollection("thoughts");

const sortedPosts = getSortedPosts(posts);
const sortedThoughts = getSortedThoughts(thoughts);

// Create a unified feed sorted by date
type FeedItem =
  | { type: "post"; item: (typeof sortedPosts)[number] }
  | { type: "thought"; item: (typeof sortedThoughts)[number] };

const feed: FeedItem[] = [
  ...sortedPosts.map(item => ({ type: "post" as const, item })),
  ...sortedThoughts.map(item => ({ type: "thought" as const, item })),
].sort((a, b) => {
  const dateA = new Date(
    a.item.data.modDatetime ?? a.item.data.pubDatetime
  ).getTime();
  const dateB = new Date(
    b.item.data.modDatetime ?? b.item.data.pubDatetime
  ).getTime();
  return dateB - dateA;
});

const latestItem = feed[0];
const recentItems = feed.slice(1, SITE.postPerIndex + 1);

// Strip markdown syntax to get plain text, then take first 200 chars
function stripMarkdown(md: string): string {
  return md
    .replace(/^#{1,6}\s+.*$/gm, "") // headings
    .replace(/!\[.*?\]\(.*?\)/g, "") // images
    .replace(/\[([^\]]*)\]\(.*?\)/g, "$1") // links → text
    .replace(/[*_~`>]/g, "") // inline formatting
    .replace(/\n{2,}/g, " ") // collapse newlines
    .replace(/\n/g, " ")
    .trim();
}
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    {
      latestItem && latestItem.type === "post" && (
        <section id="latest" class:list={["pt-8 pb-6", "border-b border-border"]}>
          <h2 class="text-2xl font-semibold tracking-wide">Latest Post</h2>
          <Card variant="h3" {...latestItem.item} />
          <p class="mt-2 text-foreground/80">
            {stripMarkdown(latestItem.item.body ?? "").slice(0, 200) + "..."}
          </p>
        </section>
      )
    }
    {
      latestItem && latestItem.type === "thought" && (
        <section id="latest" class:list={["pt-8 pb-6", "border-b border-border"]}>
          <h2 class="text-2xl font-semibold tracking-wide">Latest Thought</h2>
          <ThoughtCard {...latestItem.item} />
        </section>
      )
    }

    {
      recentItems.length > 0 && (
        <section id="recent" class="pt-12 pb-6">
          <h2 class="text-2xl font-semibold tracking-wide">Recent</h2>
          <ul>
            {recentItems.map(({ type, item }) =>
              type === "post" ? (
                <Card variant="h3" {...item} />
              ) : (
                <ThoughtCard {...item} />
              )
            )}
          </ul>
        </section>
      )
    }

    <div class="my-8 flex justify-center gap-4">
      <LinkButton href="/posts/">
        All Posts
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
      <LinkButton href="/thoughts/">
        All Thoughts
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
