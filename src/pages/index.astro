---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import ThoughtCard from "@/components/ThoughtCard.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import getSortedThoughts from "@/utils/getSortedThoughts";
import { getPath } from "@/utils/getPath";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";

const posts = await getCollection("blog");
const thoughts = await getCollection("thoughts");

const sortedPosts = getSortedPosts(posts);
const sortedThoughts = getSortedThoughts(thoughts);

// Create a unified feed sorted by date
type FeedItem =
  | { type: "post"; item: (typeof sortedPosts)[number] }
  | { type: "thought"; item: (typeof sortedThoughts)[number] };

const feed: FeedItem[] = [
  ...sortedPosts.map(item => ({ type: "post" as const, item })),
  ...sortedThoughts.map(item => ({ type: "thought" as const, item })),
].sort((a, b) => {
  const dateA = new Date(
    a.item.data.modDatetime ?? a.item.data.pubDatetime
  ).getTime();
  const dateB = new Date(
    b.item.data.modDatetime ?? b.item.data.pubDatetime
  ).getTime();
  return dateB - dateA;
});

const feedItems = feed.slice(0, 10);
const sidebarPosts = sortedPosts.slice(0, 5);

// Strip markdown syntax to get plain text, then take first 200 chars
function stripMarkdown(md: string): string {
  return md
    .replace(/^#{1,6}\s+.*$/gm, "") // headings
    .replace(/!\[.*?\]\(.*?\)/g, "") // images
    .replace(/\[([^\]]*)\]\(.*?\)/g, "$1") // links → text
    .replace(/[*_~`>]/g, "") // inline formatting
    .replace(/\n{2,}/g, " ") // collapse newlines
    .replace(/\n/g, " ")
    .trim();
}
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index">
    <div class="mx-auto max-w-5xl px-4">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_250px] gap-8">
        <!-- Main feed -->
        <div>
          <ul class="pt-8">
            {feedItems.map(({ type, item }) =>
              type === "post" ? (
                <li class="border-b border-border pb-4 mb-4">
                  <Card variant="h3" {...item} />
                  <p class="mt-2 text-foreground/80">
                    {stripMarkdown(item.body ?? "").slice(0, 200) + "..."}
                  </p>
                </li>
              ) : (
                <li class="border-b border-border pb-4 mb-4">
                  <ThoughtCard {...item} />
                </li>
              )
            )}
          </ul>

          <div class="my-8 flex justify-center gap-4">
            <LinkButton href="/posts/">
              All Posts
              <IconArrowRight class="inline-block rtl:-rotate-180" />
            </LinkButton>
            <LinkButton href="/thoughts/">
              All Thoughts
              <IconArrowRight class="inline-block rtl:-rotate-180" />
            </LinkButton>
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="lg:sticky lg:top-20 lg:self-start pt-8">
          <h2 class="text-lg font-semibold mb-4">Recent Posts</h2>
          <ul class="space-y-2">
            {sidebarPosts.map(post => (
              <li>
                <a
                  href={getPath(post.id, post.filePath)}
                  class="text-sm text-foreground/80 hover:text-accent transition-colors"
                >
                  {post.data.title}
                </a>
              </li>
            ))}
          </ul>
        </aside>
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
